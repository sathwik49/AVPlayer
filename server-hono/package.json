    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "mongoose": "^8.5.1",
    "pg": "^8.12.0",
    "postgres": "^3.4.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240718.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.11",
    "@types/pg": "^8.11.6",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.23.0",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
